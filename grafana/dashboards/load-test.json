  "panels": [
    {
      "type": "row",
      "title": "Throughput & errors",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Request rate by endpoint (req/s)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "fillOpacity": 30, "stacking": {"mode": "normal"}, "lineWidth": 1},
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(http_requests_total[1m]))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error rate (non-2xx) by endpoint (req/s)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "id": 2,
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(http_requests_total{status!~\"2..\"}[1m]))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Latency",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 101,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 by endpoint",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 3,
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "fillOpacity": 0, "lineWidth": 1}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP p50 / p95 / p99 (all endpoints)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "id": 4,
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "fillOpacity": 0, "lineWidth": 1}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Sub-latency p95: total vs redis vs mysql",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 18},
      "id": 5,
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "fillOpacity": 0, "lineWidth": 1}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "total · {{endpoint}}", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(redis_operation_duration_seconds_bucket[5m])))", "legendFormat": "redis · {{endpoint}}", "refId": "B"},
        {"expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(mysql_query_duration_seconds_bucket[5m])))", "legendFormat": "mysql · {{endpoint}}", "refId": "C"}
      ]
    },
    {
      "type": "row",
      "title": "Co-location: latency by node",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 26},
      "id": 102,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "p95 by node label (primary vs secondary)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 27},
      "id": 6,
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, node, endpoint) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{node}} · {{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Pods & scaling",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 35},
      "id": 103,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "App replicas (deployment vs HPA current)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 36},
      "id": 7,
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "stepAfter"}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "kube_deployment_status_replicas{deployment=\"load-test-app\"}", "legendFormat": "deployment.replicas", "refId": "A"},
        {"expr": "kube_deployment_status_replicas_ready{deployment=\"load-test-app\"}", "legendFormat": "deployment.ready", "refId": "B"},
        {"expr": "kube_horizontalpodautoscaler_status_current_replicas{horizontalpodautoscaler=\"load-test-app\"}", "legendFormat": "hpa.current", "refId": "C"}
      ]
    },
    {
      "type": "table",
      "title": "Pod → node map (live)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 36},
      "id": 8,
      "options": {"showHeader": true},
      "transformations": [
        {"id": "labelsToFields", "options": {"mode": "columns"}},
        {"id": "organize", "options": {"excludeByName": {"Time": true, "Value": true, "__name__": true, "instance": true, "job": true, "namespace": true, "host_ip": true, "pod_ip": true, "uid": true, "host_network": true, "created_by_kind": true, "created_by_name": true, "node_template_hash": true, "pod_template_hash": true}}}
      ],
      "targets": [
        {
          "expr": "kube_pod_info{namespace=\"load-test\", pod=~\"load-test-app-.*\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
